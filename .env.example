# Copia este archivo como .env y ajusta los valores.
# Nunca subas el token real a un repositorio.

TELEGRAM_BOT_TOKEN=REEMPLAZA_CON_TOKEN_DE_BOTFATHER
AUTHORIZED_CHAT_ID=123456789
REGISTRATION_MODE=false

# Si es true, el bot permite controlar servicios systemd instalados en el servidor.
# Requiere regenerar sudoers con scripts/create_sudoers.sh __ALL_SYSTEMD_SERVICES__.
ALLOW_ALL_SYSTEMD_SERVICES=false

# Servicios systemd que el bot puede administrar, separados por coma.
# Se usa solo si ALLOW_ALL_SYSTEMD_SERVICES=false.
ALLOWED_SERVICES=ssh,nginx

SERVICE_NAME=debian-telegram-admin-bot
INSTALL_PATH=/opt/debian-telegram-admin-bot
LOG_FILE=/opt/debian-telegram-admin-bot/logs/bot.log

CONFIRM_TTL_SECONDS=180
COMMAND_TIMEOUT_SECONDS=30
MAX_TELEGRAM_MESSAGE_LENGTH=3500
